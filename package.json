{
  "name": "hasaan-portfolio",
  "version": "1.1.0",
  "description": "Data Engineer & BI Developer Portfolio",
  "main": "index.html",
  "scripts": {
    "build": "npm run build:css && npm run build:js && npm run bump && npm run build:html",
    "bump": "node scripts/bump-version.js",
    "build:css": "postcss src/input.css -o dist/styles.css --env production",
    "build:js": "node scripts/build-js.js",
    "build:html": "node scripts/build-html.js",
    "dev": "postcss src/input.css -o dist/styles.css --watch",
    "serve": "npx serve .",
    "optimize": "npm run build && npm run compress",
    "compress": "node scripts/compress.js",
    "deploy": "node scripts/deploy.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hasaan-01/Hasaan-01.github.io.git"
  },
  "keywords": ["portfolio", "power-bi", "data-engineer", "business-intelligence"],
  "author": "Muhammad Hasaan",
  "license": "ISC",
  "devDependencies": {
    "autoprefixer": "^10.5.4",
    "cssnano": "^7.0.6",
    "html-minifier-terser": "^7.2.0",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.0",
    "tailwindcss": "^3.4.19",
    "terser": "^5.37.0"
  }
}
